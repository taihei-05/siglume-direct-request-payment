{
  "name": "@siglume/direct-request-payment",
  "version": "0.4.23",
  "description": "SDK for the Siglume Direct Request Payment SDRP payment protocol",
  "keywords": [
    "siglume",
    "sdrp",
    "direct-request-payment",
    "payment",
    "micropayments",
    "metered-billing",
    "wallet",
    "jpyc",
    "usdc",
    "checkout",
    "sdk"
  ],
  "license": "MIT",
  "author": "Siglume Contributors",
  "homepage": "https://github.com/taihei-05/siglume-direct-request-payment#readme",
  "bugs": {
    "url": "https://github.com/taihei-05/siglume-direct-request-payment/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taihei-05/siglume-direct-request-payment.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "siglume-sdrp": "./bin/siglume-sdrp.mjs",
    "siglume-check": "./bin/siglume-sdrp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "docs",
    "examples",
    "templates",
    "!examples/**/node_modules",
    "!examples/**/__pycache__",
    "!examples/**/*.pyc",
    "!templates/**/__pycache__",
    "!templates/**/*.pyc",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "npm run typecheck",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "pack:check": "npm pack --json"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.16.5",
    "@types/sql.js": "^1.4.11",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "sql.js": "^1.14.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
